# Posthorn — example environment variables.
# Copy this file to .env, then fill in the required values.
# All variables are optional; the defaults work for local development.

# ---------------------------------------------------------------------------
# Required for production
# ---------------------------------------------------------------------------

# Admin token for the operator control-plane API (/v1/admin/*) and dashboard.
# Must be at least 16 characters; use a long random value in production.  Generate one with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
# Leave unset to disable the admin API and dashboard entirely (default).
POSTHORN_ADMIN_TOKEN=

# ---------------------------------------------------------------------------
# Common settings
# ---------------------------------------------------------------------------

POSTHORN_PORT=3000
POSTHORN_HOST=0.0.0.0
POSTHORN_DATA_DIR=./posthorn-data

# Maximum request-body size in bytes; a larger request is rejected with 413.
POSTHORN_MAX_BODY_BYTES=1000000

# ---------------------------------------------------------------------------
# Worker tuning
# ---------------------------------------------------------------------------

POSTHORN_WORKER_BATCH_SIZE=16
POSTHORN_WORKER_CONCURRENCY=8
POSTHORN_WORKER_REQUEST_TIMEOUT_MS=10000
POSTHORN_WORKER_IDLE_POLL_MS=1000
POSTHORN_WORKER_VISIBILITY_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# Endpoint auto-disable
# ---------------------------------------------------------------------------

# How long (ms) an endpoint must be continuously failing before it is
# automatically disabled.  Default: 432000000 (5 days).  Set to 0 to disable
# the feature (health is still tracked, but endpoints are never auto-disabled).
POSTHORN_ENDPOINT_AUTO_DISABLE_AFTER_MS=432000000

# ---------------------------------------------------------------------------
# Transactional outbox / fan-out dispatcher
# ---------------------------------------------------------------------------

POSTHORN_FANOUT_GRACE_MS=5000
POSTHORN_FANOUT_BATCH_SIZE=50
POSTHORN_FANOUT_IDLE_POLL_MS=5000

# ---------------------------------------------------------------------------
# Data retention (pruning)
# ---------------------------------------------------------------------------

# Delete delivered/expired data older than this many days on an hourly sweep.
# 0 (the default) disables pruning entirely — stores grow unbounded.  When set,
# the minimum is 1.
POSTHORN_RETENTION_DAYS=0

# ---------------------------------------------------------------------------
# Delivery rate limiting
# ---------------------------------------------------------------------------

# Gateway-wide default delivery rate limit, in deliveries per minute, applied to
# any endpoint that has no explicit per-endpoint rate limit.  Leave unset for no
# gateway default (such endpoints are unrestricted).  Range when set: 1–10000.
POSTHORN_DEFAULT_RATE_LIMIT=

# ---------------------------------------------------------------------------
# SSRF protection (webhook destination address policy)
# ---------------------------------------------------------------------------

# Posthorn is a webhook *sender*, so endpoint URLs are tenant-controlled and a
# textbook Server-Side Request Forgery vector.  By default (false) it refuses to
# register an endpoint whose URL targets a private/internal address — loopback,
# RFC 1918 / link-local / CGNAT ranges, the cloud-metadata IP (169.254.169.254),
# or an internal hostname (localhost, *.local, *.internal, or a bare single-label
# name like `redis`) — rejecting it with 400 url_not_allowed.
# Set this to true ONLY for a trusted single-tenant self-host that legitimately
# delivers to internal services on a private network.  In a multi-tenant / hosted
# deployment, leave it false.
POSTHORN_ALLOW_PRIVATE_NETWORK_WEBHOOKS=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Minimum severity of structured (JSON Lines) log output written to stdout:
# debug | info | warn | error | silent.  Default: info — shows request access
# lines and errors while keeping the /healthz and /metrics probe traffic (logged
# at debug) quiet.  Use debug to include probes, warn/error to reduce volume, or
# silent to turn logging off entirely.
POSTHORN_LOG_LEVEL=info
