# Posthorn — example environment variables.
# Copy this file to .env, then fill in the required values.
# All variables are optional; the defaults work for local development.

# ---------------------------------------------------------------------------
# Required for production
# ---------------------------------------------------------------------------

# Admin token for the operator control-plane API (/v1/admin/*) and dashboard.
# Must be at least 16 characters; use a long random value in production.  Generate one with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
# Leave unset to disable the admin API and dashboard entirely (default).
POSTHORN_ADMIN_TOKEN=

# ---------------------------------------------------------------------------
# Common settings
# ---------------------------------------------------------------------------

POSTHORN_PORT=3000
POSTHORN_HOST=0.0.0.0

# Storage backend.  Leave POSTHORN_DATABASE_URL unset (the default) to use the
# embedded SQLite backend — one file per store under POSTHORN_DATA_DIR, the
# zero-dependency "single process, no external database" deployment.  Set it to a
# Postgres connection string (postgres:// or postgresql://) to back every store with
# one shared Postgres database instead — the horizontally-scalable path for
# active/active replicas and the hosted tier.  When set, POSTHORN_DATA_DIR is unused.
# The schema is created/migrated automatically on first boot.  Example:
#   POSTHORN_DATABASE_URL=postgres://posthorn:secret@db:5432/posthorn?sslmode=require
POSTHORN_DATA_DIR=./posthorn-data
POSTHORN_DATABASE_URL=

# Maximum connections the shared Postgres pool opens (PostgreSQL backend only;
# ignored on SQLite).  Default 10 (matches the pg driver's own default, so leaving
# it unset changes nothing).  Every replica opens up to this many connections
# against the one database, so keep (replicas × this value) under the server's
# max_connections.  Lower it when running many replicas on a small/managed database;
# raise it for a single busy replica needing more delivery concurrency.
POSTHORN_PG_POOL_MAX=10

# Canonical public base URL used to build portal-session links (the `portalUrl`
# returned by POST /v1/portal/sessions).  Leave unset to derive it from each
# request's Host header + X-Forwarded-Proto (the default).  Set it to your public
# origin (e.g. https://hooks.example.com) when running behind a host-rewriting proxy
# — where the Host header reaching Posthorn is the gateway's internal name, not the
# public one — so portal links point at the right place without trusting a
# client-settable header.  Must be a bare http(s) origin: scheme + host (+ port),
# no path/query/fragment.
POSTHORN_PUBLIC_BASE_URL=

# Maximum request-body size in bytes; a larger request is rejected with 413.
POSTHORN_MAX_BODY_BYTES=1000000

# HTTP socket-lifetime timeouts (all in ms; 0 disables a timeout).  Defaults match
# Node's own, so leaving these unset changes nothing.  Two reasons to set them:
#  - Behind a connection-pooling reverse proxy / load balancer, raise the keep-alive
#    timeout ABOVE the LB's idle timeout (AWS ALB 60s, nginx 75s, …) to avoid the
#    upstream-502 race where the LB reuses a socket Posthorn just closed.  See DEPLOY.md.
#  - Tighten the headers/request deadlines (Slowloris bounds) for an internet-facing
#    ingest endpoint — a normal webhook POST completes in well under a second.
# Constraint: HEADERS_TIMEOUT must be <= REQUEST_TIMEOUT when both are non-zero.
POSTHORN_HTTP_KEEP_ALIVE_TIMEOUT_MS=5000
POSTHORN_HTTP_HEADERS_TIMEOUT_MS=60000
POSTHORN_HTTP_REQUEST_TIMEOUT_MS=300000

# Graceful-shutdown drain window (ms).  On SIGTERM/SIGINT the gateway stops accepting
# new connections and lets in-flight requests finish; any socket still active after
# this window is force-closed so a slow/stuck request can't delay shutdown past the
# orchestrator's termination grace.  0 disables the cutoff (drain is then bounded only
# by REQUEST_TIMEOUT).  Keep this at or below your Kubernetes terminationGracePeriodSeconds
# / `docker stop -t` so the drain finishes before SIGKILL.
POSTHORN_HTTP_SHUTDOWN_GRACE_MS=10000

# ---------------------------------------------------------------------------
# Worker tuning
# ---------------------------------------------------------------------------

POSTHORN_WORKER_BATCH_SIZE=16
POSTHORN_WORKER_CONCURRENCY=8
# Total per-attempt timeout: DNS + connect + the receiver's full response.
POSTHORN_WORKER_REQUEST_TIMEOUT_MS=10000
# Connect-only deadline (DNS + TCP connect) so an unreachable endpoint fails fast.
# Should be <= the total timeout above; 0 disables it.
POSTHORN_WORKER_CONNECT_TIMEOUT_MS=5000
POSTHORN_WORKER_IDLE_POLL_MS=1000
POSTHORN_WORKER_VISIBILITY_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# Endpoint auto-disable
# ---------------------------------------------------------------------------

# How long (ms) an endpoint must be continuously failing before it is
# automatically disabled.  Default: 432000000 (5 days).  Set to 0 to disable
# the feature (health is still tracked, but endpoints are never auto-disabled).
POSTHORN_ENDPOINT_AUTO_DISABLE_AFTER_MS=432000000

# ---------------------------------------------------------------------------
# Transactional outbox / fan-out dispatcher
# ---------------------------------------------------------------------------

POSTHORN_FANOUT_GRACE_MS=5000
POSTHORN_FANOUT_BATCH_SIZE=50
POSTHORN_FANOUT_IDLE_POLL_MS=5000

# ---------------------------------------------------------------------------
# Data retention (pruning)
# ---------------------------------------------------------------------------

# Delete delivered/expired data older than this many days on an hourly sweep.
# 0 (the default) disables pruning entirely — stores grow unbounded.  When set,
# the minimum is 1.
POSTHORN_RETENTION_DAYS=0

# ---------------------------------------------------------------------------
# Delivery rate limiting
# ---------------------------------------------------------------------------

# Gateway-wide default delivery rate limit, in deliveries per minute, applied to
# any endpoint that has no explicit per-endpoint rate limit.  Leave unset for no
# gateway default (such endpoints are unrestricted).  Range when set: 1–10000.
POSTHORN_DEFAULT_RATE_LIMIT=

# ---------------------------------------------------------------------------
# SSRF protection (webhook destination address policy)
# ---------------------------------------------------------------------------

# Posthorn is a webhook *sender*, so endpoint URLs are tenant-controlled and a
# textbook Server-Side Request Forgery vector.  By default (false) it refuses to
# register an endpoint whose URL targets a private/internal address — loopback,
# RFC 1918 / link-local / CGNAT ranges, the cloud-metadata IP (169.254.169.254),
# or an internal hostname (localhost, *.local, *.internal, or a bare single-label
# name like `redis`) — rejecting it with 400 url_not_allowed.
# Set this to true ONLY for a trusted single-tenant self-host that legitimately
# delivers to internal services on a private network.  In a multi-tenant / hosted
# deployment, leave it false.
POSTHORN_ALLOW_PRIVATE_NETWORK_WEBHOOKS=false

# ---------------------------------------------------------------------------
# HTTP Strict Transport Security (HSTS)
# ---------------------------------------------------------------------------

# Emit a Strict-Transport-Security response header (force HTTPS for this many
# seconds).  0 (the default) disables it — no header is sent.  HSTS is ONLY safe
# once this origin is genuinely reached over HTTPS (Posthorn terminates TLS at an
# upstream proxy; the header reaches the browser over that HTTPS hop).  An
# over-long max-age published before a host/subdomain is TLS-ready locks it out of
# plain HTTP for the whole window — so enable deliberately.  Start small (e.g.
# 86400 = 1 day) and ramp up; 31536000 (1 year) is the long-lived value.
POSTHORN_HSTS_MAX_AGE=0

# Apply the policy to every subdomain too (appends "; includeSubDomains").
# Requires POSTHORN_HSTS_MAX_AGE > 0.  Only set this once EVERY subdomain of the
# origin is served over HTTPS, or they become unreachable over plain HTTP.
POSTHORN_HSTS_INCLUDE_SUBDOMAINS=false

# Opt into browser HSTS preload lists (appends "; preload").  Requires
# includeSubDomains=true and a max-age of at least 31536000 (1 year), per the
# preload-list submission rules; otherwise startup fails fast.  Preloading is hard
# to undo — only enable when you are certain the whole domain is HTTPS-only.
POSTHORN_HSTS_PRELOAD=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Minimum severity of structured (JSON Lines) log output written to stdout:
# debug | info | warn | error | silent.  Default: info — shows request access
# lines and errors while keeping the /healthz, /readyz, and /metrics probe traffic
# (logged at debug) quiet.  Use debug to include probes, warn/error to reduce volume, or
# silent to turn logging off entirely.
POSTHORN_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Billing (optional, disabled by default)
# ---------------------------------------------------------------------------

# Which billing backend to wire: none (the default) or stripe.  When "none",
# Posthorn carries no payment dependency: metered-usage pushes are silently
# dropped and POST /v1/billing/webhook is 404.  Set to "stripe" to meter usage
# to Stripe and accept Stripe-signed webhooks (the Stripe vars below apply).
POSTHORN_BILLING_PROVIDER=none

# Stripe secret API key (sk_…).  REQUIRED when POSTHORN_BILLING_PROVIDER=stripe
# (startup fails fast otherwise); ignored when the provider is "none".  Sent as
# the Bearer credential on outbound Stripe API calls — keep it secret.
POSTHORN_STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_…).  Optional even under the stripe
# provider: when unset, outbound usage pushes still work but the inbound
# POST /v1/billing/webhook route stays 404 (the inbound surface is opt-in, like
# the admin API).  Set it to enable and verify inbound Stripe webhooks.
POSTHORN_STRIPE_WEBHOOK_SECRET=

# The Stripe meter event_name a metered-usage push is recorded under (Stripe
# Billing Meter Events API).  Default: posthorn_messages.  Must match the meter
# you configured in Stripe.  Ignored when the provider is "none".
POSTHORN_STRIPE_METER_EVENT_NAME=posthorn_messages
