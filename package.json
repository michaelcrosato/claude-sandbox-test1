{
  "name": "posthorn",
  "version": "1.0.0",
  "description": "Open-core, Standard Webhooks-compliant reliable webhook delivery infrastructure. Single container, no Redis.",
  "type": "module",
  "license": "MIT",
  "author": "Michael Crosato",
  "repository": {
    "type": "git",
    "url": "https://github.com/michaelcrosato/claude-sandbox-test1"
  },
  "keywords": [
    "webhook",
    "webhook-delivery",
    "standard-webhooks",
    "reliable-delivery",
    "sqlite",
    "no-redis",
    "open-core"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "posthorn": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:site": "node scripts/build-site.mjs",
    "bench": "node bench/throughput.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "agent:check": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "pg": "^8.21.0"
  }
}
