# Keep the build context minimal and reproducible: ship only the sources the
# builder compiles (src/, package*.json, tsconfig.json). Everything below is
# either rebuilt in-image, host-only, or runtime state that must never bake in.
node_modules
dist
.git
.gitignore
coverage
docs
scripts
*.log
*.sqlite
*.sqlite-journal
posthorn-data
.env
.env.*
README.md
LICENSE
Dockerfile
.dockerignore
